# Inspired from https://github.com/github/gitignore

# Unix
*~

# OSX
.AppleDouble
.DS_Store
.LSOverride
.Spotlight-V100
.Trashes
._*

# Vim
*.un~
.*.s[a-w][a-z]
.netrwhist
Session.vim

# Xcode
!default.mode1v3
!default.mode2v3
!default.pbxuser
!default.perspectivev3
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
*.perspectivev3
*.xccheckout
*.xcuserstate
DerivedData
xcuserdata

# Secrets
.env
.env.local
.env*.local

# Python
__pycache__/
*.pyc

# Terraform
.terraform/

# Logs
*.log

# Node.js
npm-debug.log

# JetBrains IDEs
*.iml
*.ipr
*.iws
.idea/
.idea_modules/
/out/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics-build.properties
crashlytics.properties

# Haskell
.hdevtools*

# Visual Studio Code
.vscode

# Homebrew
*.lock.json

# lazy.nvim
lazy-lock.json

# tmux
.tmux/plugins/

# zsh
.zsh/bundle/

# Claude
.claude/*
!.claude/CLAUDE.md
!.claude/settings.json
!.claude/skills
!.claude/statusline-command.sh
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/peon-ping/
.claude/hooks/peon-ping/*
!.claude/hooks/peon-ping/codex-hook.sh
.claude/settings.local.json

# Codex
.codex/*
!.codex/AGENTS.md
!.codex/config.toml
!.codex/rules/
!.codex/skills

# Cursor
.cursor/
!.cursor/hooks.json

# OpenPeon (runtime state)
.openpeon/.last_update_check
.openpeon/.sound.pid
.openpeon/.state.json

# Codex system skills (auto-managed)
.agents/skills/.system/

# Shared agent memory (managed separately)
.agents/memories/

*.lock
automatic_backups/
